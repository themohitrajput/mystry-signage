# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/mystry_signage

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
COOKIE_EXPIRES_DAYS=7

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Admin bootstrap (used by seed script)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@mystrysignage.com
ADMIN_PASSWORD=ChangeMe123!

# Email (Nodemailer - example uses Gmail SMTP / any SMTP provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Mystry Signage Website" <no-reply@mystrysignage.com>
EMAIL_TO=owner@mystrysignage.com

# Uploads
MAX_UPLOAD_MB=5
